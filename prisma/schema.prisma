generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model File {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  telegramId  String
  messageId   String
  size        Int
  mimeType    String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  shards      Shard[]
}

model Shard {
  id          String   @id @default(cuid())
  fileId      String
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  shardIndex  Int
  telegramId  String
  messageId   String
  size        Int
  dcName      String
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  key       String    @unique
  name      String
  type      String    // "production" or "test"
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
}

