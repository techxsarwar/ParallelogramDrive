generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model File {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  telegramId  String
  messageId   String
  size        Int
  mimeType    String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
