generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model File {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  telegramId  String
  messageId   String
  size        Int
  mimeType    String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  key       String    @unique
  name      String
  type      String    // "production" or "test"
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
}

